# ─────────────────────────────────────────────────────────────
# Fridge AI — environment variables
# Copy this file to `.env.local` and fill in real values.
#
# The app runs WITHOUT any of these set (demo mode):
#   • Storage falls back to a local JSON file (.data/fridge.json)
#   • AI falls back to a deterministic mock provider
# Add the keys below to switch to real Supabase + Gemini.
# ─────────────────────────────────────────────────────────────

# --- Supabase (optional) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side key (preferred for writes; bypasses RLS). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Gemini (optional) ---
GEMINI_API_KEY=your-gemini-api-key
# Vision-capable model. Recommended for current keys: gemini-2.5-flash (fast, stable)
# or gemini-3.5-flash (newer, slower, vision can intermittently 503 — auto-retried).
# Note: gemini-2.0-flash / gemini-1.5-flash may 429/404 depending on key tier.
GEMINI_MODEL=gemini-2.5-flash

# --- App (optional) ---
# Single demo user the inventory is stored under.
DEMO_USER_ID=demo-user
# Directory for the local JSON store when Supabase is not configured.
# On read-only hosts (e.g. Vercel) set this to /tmp.
# DATA_DIR=.data
