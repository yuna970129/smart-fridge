# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
DATABASE_URL=sqlite:///./data/naengbu.db
# Comma-separated list of allowed CORS origins for the React dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── LLM provider ─────────────────────────────────────────────────────────────
# Which provider to use: "azure_openai" or "mock".
# Leave as "mock" until Azure credentials are provided — the app runs fully
# offline with deterministic mock responses so the demo never blocks on auth.
LLM_PROVIDER=mock

# Azure OpenAI (fill these in later — the user will provide auth)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Deployment name of a multimodal (vision-capable) chat model, e.g. gpt-4o
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Receipt parser ───────────────────────────────────────────────────────────
# "llm_vision" (image -> LLM -> JSON, default) or "clova_hybrid" (CLOVA OCR ->
# text -> LLM normalize). clova_hybrid is a documented extension point and is
# NOT implemented yet — it raises NotImplementedError until CLOVA creds exist.
RECEIPT_PARSER=llm_vision
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=

# ── Recipe source ────────────────────────────────────────────────────────────
# "llm_gen" (LLM-generated, primary), "seed_db" (curated seed DB matching),
# or "hybrid" (seed DB first, top up with LLM generation).
RECIPE_SOURCE=hybrid
